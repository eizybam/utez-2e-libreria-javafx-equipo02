<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="257.0" prefWidth="353.0" spacing="10.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.resources.library.controllers.AddController">
   <children>
      <TextField fx:id="txtIsbn" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="40.0" prefWidth="200.0" promptText="ISBN">
         <VBox.margin>
            <Insets />
         </VBox.margin></TextField>
      <TextField fx:id="txtTitle" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="40.0" prefWidth="200.0" promptText="Title">
         <VBox.margin>
            <Insets />
         </VBox.margin></TextField>
      <TextField fx:id="txtAuthor" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="40.0" prefWidth="200.0" promptText="Author">
         <VBox.margin>
            <Insets />
         </VBox.margin></TextField>
      <TextField fx:id="txtYearPublished" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="40.0" prefWidth="200.0" promptText="Year">
         <VBox.margin>
            <Insets />
         </VBox.margin></TextField>
      <VBox alignment="TOP_CENTER" prefHeight="86.0" prefWidth="351.0" spacing="7.0">
         <children>
            <ComboBox fx:id="cbGenreFilter" prefHeight="30.0" prefWidth="150.0" promptText="Genre" />
            <CheckBox fx:id="chkAvailable" mnemonicParsing="false" prefHeight="41.0" prefWidth="69.0" text="Available" />
            <HBox alignment="TOP_CENTER" prefHeight="43.0" prefWidth="576.0" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#onCancelAdd" text="Cancel">
                     <HBox.margin>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                     </HBox.margin>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#onSave" prefHeight="25.0" prefWidth="60.0" text="Save">
                     <HBox.margin>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</VBox>
